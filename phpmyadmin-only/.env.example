# ---------------------------------------------------------------------------
# phpMyAdmin (standalone) configuration. Copy to `.env` and adjust.
#
#   cp .env.example .env
#
# There are NO passwords here — you log in with your MySQL credentials in the
# phpMyAdmin UI.
# ---------------------------------------------------------------------------

# Which database server should phpMyAdmin talk to?
#   * DB on this machine / Docker Desktop : host.docker.internal
#   * Remote server                       : db.example.com  (or an IP)
#   * DB in another Docker network        : the DB's service name, e.g. db
#                                           (also uncomment the external network
#                                            recipe in docker-compose.yml)
PMA_HOST=host.docker.internal
PMA_PORT=3306

# Show a free-form "Server" field on the login page so you can connect to any
# host? Convenient but less safe. Leave 0 to lock phpMyAdmin to PMA_HOST.
PMA_ARBITRARY=0

# Local port for the UI (bound to 127.0.0.1 only).
PMA_HOST_PORT=8080

# Public URL used to build correct redirects (set your https URL behind a proxy).
PMA_ABSOLUTE_URI=http://localhost:8080/

# Max import / upload size.
PMA_UPLOAD_LIMIT=64M
