# ---------------------------------------------------------------------------
# Non-secret configuration. Copy this file to `.env` and adjust as needed.
#
#   cp .env.example .env
#
# Passwords do NOT live here — they are Docker secrets under ./secrets/.
# ---------------------------------------------------------------------------

# Application database and user, created automatically on first boot.
# The app user receives full privileges on MYSQL_DATABASE only (least privilege).
MYSQL_DATABASE=appdb
MYSQL_USER=appuser

# phpMyAdmin host port. Bound to 127.0.0.1 (loopback) in compose, so only this
# machine can reach it. Change it to avoid clashes with other local services.
PMA_HOST_PORT=8080

# MySQL host port. Used ONLY if you opt in to exposing the database to the host
# (see the commented recipe under the `db` service in docker-compose.yml).
# By default MySQL is not published to the host at all.
MYSQL_HOST_PORT=3306

# Public URL phpMyAdmin is served from (used to build correct redirects).
# If you serve it behind a reverse proxy, set the external https URL here.
PMA_ABSOLUTE_URI=http://localhost:8080/

# Maximum import / upload size in phpMyAdmin.
PMA_UPLOAD_LIMIT=64M
